<script>
    // Minimal scroll behavior for FAB
    let lastScroll = 0;
    const fabContainer = document.querySelector('.fixed.bottom-24');
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      if (currentScroll > lastScroll && currentScroll > 60) {
        fabContainer.style.opacity = '0.3';
        fabContainer.style.transform = 'translateY(10px)';
        fabContainer.style.pointerEvents = 'none';
      } else {
        fabContainer.style.opacity = '1';
        fabContainer.style.transform = 'translateY(0)';
        fabContainer.style.pointerEvents = 'auto';
      }
      lastScroll = currentScroll;
    });
  </script>
